{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "kill port 19876",
            "type": "shell",
            "command": "PID=$(lsof -ti:19876 2>/dev/null); if [ -n \"$PID\" ]; then kill -9 $PID && echo 'killed existing backend'; else echo 'port 19876 free'; fi",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "start backend (replay)",
            "type": "shell",
            "command": "ART=\"${env:ARTIFACTS_PATH}\"; [ -z \"$ART\" ] && ART=\"${workspaceFolder}/artifacts\"; [[ \"$ART\" != /* ]] && ART=\"${workspaceFolder}/$ART\"; cd \"${workspaceFolder}\" && uv run python -m engine --token testtoken --jquants-catalog-path \"$ART/jquants-catalog\"",
            "isBackground": true,
            "dependsOn": [
                "kill port 19876"
            ],
            "problemMatcher": {
                "pattern": {
                    "regexp": "^NOMATCH$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Starting gRPC server on port 19876"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "backend"
            }
        },
        {
            "label": "stop backend (replay)",
            "type": "shell",
            "command": "PID=$(lsof -ti:19876 2>/dev/null); if [ -n \"$PID\" ]; then kill -9 $PID && echo 'backend stopped'; else echo 'backend already stopped'; fi",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "replay: prepare",
            "dependsOn": [
                "cargo build",
                "start backend (replay)"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}
